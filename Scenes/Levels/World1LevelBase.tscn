[sub_resource type="GDScript" id="GDScript_hjvo4"]
script/source = "@tool extends Parallax2D

@export_tool_button(\"Run\") var run := _run

func _run() -> void:
	
	for child in get_children(): if child is Polygon2D:
		child.global_position.x = wrap(child.global_position.x, 0.0, 2048.)
		child.global_position.y = wrap(child.global_position.y, 0.0, 2048.)
		#
		#var offset:Vector2 = child.polygon[0]
		#var new:Array = Array(child.polygon.duplicate())
		#for i in range(len(new)):
			#new[i] = new[i] - offset
		#child.polygon = new
		#child.global_position += offset
"

